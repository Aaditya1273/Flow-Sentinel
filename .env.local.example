# ─────────────────────────────────────────────────────────────────
# Flow Sentinel — Environment Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this to .env.local and fill in your values.
# cp .env.local.example .env.local
# ─────────────────────────────────────────────────────────────────

# ── Flow Blockchain ────────────────────────────────────────────
# Flow Access Node API endpoint
NEXT_PUBLIC_FLOW_ACCESS_NODE=https://rest-testnet.onflow.org

# Contract address where SentinelVaultFinal is deployed
NEXT_PUBLIC_SENTINEL_VAULT_ADDRESS=0xc13b08053be24e87

# Contract address for SentinelInterfaces
NEXT_PUBLIC_SENTINEL_INTERFACES_ADDRESS=0x136b642d0aa31ca9

# Contract address for StrategyRegistry
NEXT_PUBLIC_STRATEGY_REGISTRY_ADDRESS=0xc13b08053be24e87

# Flow Token contract address (testnet)
NEXT_PUBLIC_FLOW_TOKEN_ADDRESS=0x7e60df042a9c0868

# Fungible Token contract address (testnet)
NEXT_PUBLIC_FUNGIBLE_TOKEN_ADDRESS=0x9a0766d93b6608b7

# Strategy contract addresses (all at same address on testnet)
NEXT_PUBLIC_LIQUID_STAKING_STRATEGY_ADDRESS=0xc13b08053be24e87
NEXT_PUBLIC_YIELD_FARMING_STRATEGY_ADDRESS=0xc13b08053be24e87
NEXT_PUBLIC_ARBITRAGE_STRATEGY_ADDRESS=0xc13b08053be24e87

# ── WalletConnect (Required for EVM wallet support) ────────────
# Get a project ID at https://cloud.reown.com (formerly WalletConnect)
# Without this, MetaMask / Rainbow Wallet connections will NOT work
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# ── Monitoring (Sentry) ────────────────────────────────────────
# DSN from https://sentry.io → Project Settings → Client Keys (DSN)
# If not set, error monitoring falls back to structured console logging
NEXT_PUBLIC_SENTRY_DSN=

# ── Mainnet Overrides (uncomment for production) ──────────────
# NEXT_PUBLIC_FLOW_ACCESS_NODE=https://rest-mainnet.onflow.org
# NEXT_PUBLIC_FLOW_TOKEN_ADDRESS=0x1654653399040a61
# NEXT_PUBLIC_FUNGIBLE_TOKEN_ADDRESS=0xf233dcee88fe0abe
